#!/usr/bin/env bash

set -euo pipefail

source script/env "$@"
source "$DIR/script/lib/common.sh"

echo -e "${BLUE}🥾 Bootstrapping...${OFF}"

require_macos skip "Skipping bootstrap on non-macOS host."
require_full_xcode
install_pinned_tools

generate_xcodeproj

echo -e "${GREEN}✅ Bootstrap complete!${OFF}"
